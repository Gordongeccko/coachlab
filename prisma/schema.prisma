generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      AuthSession[]
  coachSessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Exercise {
  id           String   @id @default(cuid())
  title        String
  vad          String
  varfor       String
  hur          String
  organisation String
  anvisningar  String
  images       Json     @default("[]")
  videoUrl     String?
  source       String   @default("SVFF")
  verified     Boolean  @default(true)
  category     String   @default("")
  subcategory  String   @default("")
  exerciseType String   @default("")
  createdAt    DateTime @default(now())
  sessionExercises SessionExercise[]
}

model Session {
  id        String   @id @default(cuid())
  name      String
  notes     String?
  players   Int      @default(10)
  pitchSize String   @default("Full")
  duration  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  sessionExercises SessionExercise[]
}

model SessionExercise {
  id         String   @id @default(cuid())
  order      Int
  notes      String?
  duration   Int?
  level      String?
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId  String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
  exerciseId String
}
